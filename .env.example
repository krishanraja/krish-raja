# ---------------------------------------------------------------------------
# Client-side environment variables (exposed to the browser via Vite)
# ---------------------------------------------------------------------------
# Supabase project identifier
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id
# Supabase anon / publishable key (safe for the browser)
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
# Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# ---------------------------------------------------------------------------
# Server-side secrets (Supabase Edge Functions only — never exposed to client)
# ---------------------------------------------------------------------------
# Resend transactional email API key
RESEND_API_KEY=your-resend-api-key
# Supabase service role key (full DB access — keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Supabase project URL (used by edge functions)
SUPABASE_URL=https://your-project.supabase.co
